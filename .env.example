# ─── Required for production ───────────────────────────────────────

# Strong password for /admin login (required on Vercel)
ADMIN_PASSWORD=your-secure-password-here

# Public site URL (used for sitemap, Open Graph, canonical links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Required for lead persistence ─────────────────────────────────
# Neon Postgres connection string (pooled, recommended for serverless).
# Create via Vercel: Storage → Neon → Create → Connect to project
# Or at https://neon.tech — then run: vercel env pull
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── SendLayer lead notifications ─────────────────────────────────
# The From address must use a domain verified in SendLayer.
SENDLAYER_API_KEY=
SENDLAYER_FROM_EMAIL=notifications@your-domain.com
SENDLAYER_FROM_NAME=VevadeCo
# Comma-separate multiple notification recipients.
RFP_NOTIFICATION_EMAIL=you@your-domain.com

# ─── Local development only ──────────────────────────────────────
# Without DATABASE_URL, leads are saved to data/leads.json locally.
# Default dev admin password (when ADMIN_PASSWORD is unset): vevadeco2026
